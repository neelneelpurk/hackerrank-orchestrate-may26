OPENROUTER_API_KEY=
OPENROUTER_MODEL=x-ai/grok-4.3

# Optional: pin OpenRouter provider routing order, comma-separated
# (e.g. "xAI,Together,Fireworks"). Empty = let OpenRouter choose.
OPENROUTER_PROVIDER_ORDER=

JINA_API_KEY=

# LangWatch cloud telemetry (optional). If LANGWATCH_API_KEY is set, every ADK span
# (LLM calls, tool calls, sub-agent transitions) is exported to LangWatch as well as
# to the local JSONL file at runs/telemetry-<ts>.jsonl.
LANGWATCH_API_KEY=
LANGWATCH_PROJECT_ID=
LANGWATCH_ENDPOINT=https://app.langwatch.ai

# Reflector pass threshold (final_score = 0.4g + 0.3c + 0.2s + 0.1a).
REFLECTION_PASS_THRESHOLD=5.0

# Jina embedding + rerank model selection
JINA_EMBED_MODEL=jina-embeddings-v3
JINA_RERANK_MODEL=jina-reranker-v3
JINA_DIMENSIONS=512
JINA_LATE_CHUNKING=1

# Retrieval tuning. Defaults match the multi-query + two-stage-diversity pipeline.
RETRIEVE_TOP_K=50
RETRIEVE_FINAL_N=5
# Pre-rerank source cap (chunks per source_path entering the rerank pool).
RETRIEVE_MAX_PER_SOURCE=2
# Post-rerank source cap (chunks per source_path in the final-N to the Solver).
RETRIEVE_MAX_PER_SOURCE_FINAL=1
# Drop-floor on rerank score; below this the chunk is noise.
RETRIEVE_LOW_SIGNAL_DROP=0.05
# Trigger the legacy paraphrase retry when even rerank top-1 falls below this
# (rare with multi-query default).
RETRIEVE_LOW_SIGNAL_RETRY=0.10
# HIGH/MEDIUM confidence boundary on the (top1 - last) rerank-score gap.
RETRIEVE_SCORE_GAP_AMBIGUOUS=0.08
# Confidence band thresholds on top-1 rerank score (Jina v3 range ~[0, 0.5]).
# Loosened so even small-magnitude on-topic matches reach MEDIUM, not LOW.
RETRIEVE_CONFIDENCE_HIGH_TOP=0.15
RETRIEVE_CONFIDENCE_MEDIUM_TOP=0.05

# Optional: override the chunk vote ratio in voting.py
# VOTING_TOP1_RATIO=1.5
